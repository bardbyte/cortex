FROM apache/age:latest

USER root

# Install pgvector — detect PG version dynamically
RUN apt-get update && \
    PG_VERSION=$(pg_config --version | grep -oP '\d+' | head -1) && \
    apt-get install -y postgresql-${PG_VERSION}-pgvector && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER postgres
