# =============================================================================
# Cortex Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

LOOKER_INSTANCE_URL=https://your-looker-instance.looker.com
LOOKER_CLIENT_ID=your-looker-client-id
LOOKER_CLIENT_SECRET=your-looker-client-secret

# --- Apache AGE / PostgreSQL (optional graph backend) -------------------------
# Connection details for AGE-enabled Postgres.
## These credentials are only local postgres credentials and not more of an enterprise database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_DBNAME=postgres
POSTGRES_GRAPH_PATH=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

CIBIS_CONSUMER_INTEGRATION_ID=your-cibis-integration-id
CIBIS_CONSUMER_SECRET=your-cibis-consumer-secret

CONFIG_PATH=./config/config.yml
