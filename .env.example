# =============================================================================
# Cortex Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
#
# To get credentials:
#   CIBIS: Request via IdaaS portal → Application Registration
#   Looker: Admin panel → API → API Credentials
#   GCP: gcloud auth application-default login
# =============================================================================

# --- SafeChain LLM Access (required) ----------------------------------------
# These authenticate your application to call LLMs through Amex's SafeChain proxy.
# Without these, no LLM calls will work.
CIBIS_CONSUMER_KEY=your-consumer-key
CIBIS_CONSUMER_SECRET=your-consumer-secret
CIBIS_CONFIGURATION_ID=your-configuration-id-uuid

# SafeChain configuration file path (points to config.yml with model routing).
# config.yml contains model_id and endpoint routing — NOT committed to git.
CONFIG_PATH=config.yml

# --- Looker MCP (required for data queries) ----------------------------------
# These connect to the Looker instance for SQL generation and data exploration.
# The MCP Toolbox server uses these to proxy Looker API calls.
LOOKER_INSTANCE_URL=https://your-instance.looker.com
LOOKER_CLIENT_ID=your-looker-client-id
LOOKER_CLIENT_SECRET=your-looker-client-secret

# --- MCP Toolbox Server -------------------------------------------------------
# URL where MCP Toolbox is running (local dev or GKE-deployed).
# Local: http://localhost:5000  |  GKE: http://mcp-toolbox.cortex.svc:5000
MCP_TOOLBOX_URL=http://localhost:5000

# --- Neo4j (required for graph search) ---------------------------------------
# Local: docker compose up neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- GCP (required for Vertex AI Search) -------------------------------------
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1
VERTEX_SEARCH_DATASTORE=your-datastore-id
